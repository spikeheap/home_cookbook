---
layout: default
---
<%
  page = resource.data
  prep = capture { render "duration", iso: page.prepTime }.strip
  cook = capture { render "duration", iso: page.cookTime }.strip
  body_html = content.to_s.strip

  sub_slugs = []
  Array(page.recipeIngredient).each do |section|
    Array(section["items"]).each do |item|
      text = item.is_a?(Hash) ? (item["item"] || "") : item.to_s
      next unless text.include?("](") && text.include?(".html)")
      sub_slugs << text.split("](").last.split(")").first.sub(".html", "")
    end
  end
  sub_recipes = sub_slugs.uniq.filter_map { |s| collections.recipes.resources.find { |r| r.basename_without_ext == s } }
%>
<article class="recipe"
         data-recipe-name="<%= page.name %>"
         data-recipe-slug="<%= resource.basename_without_ext %>"
         data-recipe-slot="<%= plan_slot_for(resource) %>"
         data-pagefind-body>

  <header class="recipe-head">
    <p class="recipe-cuisine" data-pagefind-meta="cuisine"><%= page.cuisine %></p>
    <h1 class="recipe-title" data-pagefind-meta="title"><%= page.name %></h1>
    <% if page.effort %><span hidden data-pagefind-meta="effort:<%= page.effort %>"></span><% end %>
    <% if page.tags %><span hidden data-pagefind-meta="tags:<%= Array(page.tags).join(", ") %>"></span><% end %>
    <% if page.description.to_s != "" %>
      <p class="recipe-blurb"><%= page.description %></p>
    <% end %>

    <ul class="recipe-stats">
      <% if page.recipeYield %>
        <li><span class="recipe-stats__label">Yield</span><span class="recipe-stats__value"><%= page.recipeYield %></span></li>
      <% end %>
      <% unless prep.empty? %>
        <li><span class="recipe-stats__label">Prep</span><span class="recipe-stats__value"><%= prep %></span></li>
      <% end %>
      <% unless cook.empty? %>
        <li><span class="recipe-stats__label">Cook</span><span class="recipe-stats__value"><%= cook %></span></li>
      <% end %>
      <% if page.effort %>
        <li><span class="recipe-stats__label">Effort</span><span class="recipe-stats__value"><%= page.effort %></span></li>
      <% end %>
    </ul>

    <div class="recipe-tools" role="toolbar" aria-label="Recipe tools">
      <button type="button" class="tool" data-tool="wakelock" aria-pressed="false">
        <span class="tool__icon" aria-hidden="true">◉</span>
        <span class="tool__label">Keep screen awake</span>
      </button>
      <div class="tool tool--scale" data-tool="scale"<% if page.servings %> data-base-servings="<%= page.servings %>"<% end %>>
        <span class="tool__label"><%= page.servings ? "Serves" : "Make" %></span>
        <button type="button" data-step="down" aria-label="Decrease">−</button>
        <span class="tool__value" data-scale-value><%= page.servings ? page.servings : "×1" %></span>
        <button type="button" data-step="up" aria-label="Increase">+</button>
      </div>
      <button type="button" class="tool" data-tool="add-to-plan">
        <span class="tool__icon" aria-hidden="true">+</span>
        <span class="tool__label">Add to plan</span>
      </button>
      <button type="button" class="tool" data-tool="print" onclick="window.print()">
        <span class="tool__icon" aria-hidden="true">⎙</span>
        <span class="tool__label">Print</span>
      </button>
    </div>
  </header>

  <% if page.image %>
    <% img = page.image.is_a?(Array) ? page.image.first : page.image %>
    <figure class="recipe-image">
      <img src="<%= relative_url(img) %>" alt="<%= page.name %>" loading="lazy" />
    </figure>
  <% end %>

  <div class="recipe-body">
    <%
      ingredient_count = Array(page.recipeIngredient).sum { |s| Array(s["items"]).size }
    %>
    <section class="recipe-ingredients" aria-label="Ingredients">
      <details class="recipe-ingredients__panel" open>
        <summary class="recipe-section-title recipe-ingredients__summary">
          Ingredients
          <span class="recipe-ingredients__count" aria-hidden="true"><%= ingredient_count %></span>
        </summary>
        <div class="recipe-ingredients__body">
          <%= render "ingredient_list", list: page.recipeIngredient %>
        </div>
      </details>
    </section>

    <section class="recipe-steps" aria-label="Method">
      <h2 class="recipe-section-title">Method</h2>
      <%= render "instruction_list", list: page.recipeInstructions %>
    </section>
  </div>

  <% unless body_html.empty? %>
    <section class="recipe-notes">
      <h2 class="recipe-section-title">Notes</h2>
      <%= content %>
    </section>
  <% end %>

  <% unless sub_recipes.empty? %>
    <section class="recipe-subs" aria-label="Sub-recipes">
      <h2 class="recipe-section-title">Sub-recipes</h2>
      <% sub_recipes.each do |sub| %>
        <article class="recipe-sub">
          <header class="recipe-sub__head">
            <h3 class="recipe-sub__title"><%= sub.data.name %></h3>
            <% if sub.data.recipeYield %><p class="recipe-sub__yield"><%= sub.data.recipeYield %></p><% end %>
          </header>
          <h4 class="recipe-sub__heading">Method</h4>
          <%= render "instruction_list", list: sub.data.recipeInstructions %>
        </article>
      <% end %>
    </section>
  <% end %>

  <% if page.isBasedOn || (page.author && page.author["name"]) %>
    <footer class="recipe-source">
      Based on
      <% if page.isBasedOn %>
        <a href="<%= page.isBasedOn %>" rel="noopener">a recipe</a>
      <% else %>
        a recipe
      <% end %>
      <% if page.author && page.author["name"] %> by <%= page.author["name"] %><% end %>.
    </footer>
  <% end %>
</article>
