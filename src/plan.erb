---
layout: default
title: Meal plan
permalink: /plan/
---
<%
  require "json"

  recipes_data = collections.recipes.resources.map do |r|
    {
      slug:             r.basename_without_ext,
      name:             r.data.name,
      url:              r.relative_url,
      servings:         r.data.servings,
      meal:             Array(r.data.meal),
      recipeYield:      r.data.recipeYield,
      recipeIngredient: r.data.recipeIngredient,
    }
  end

  # Escape `</` so a stray closing tag in any string can't break out of <script>.
  recipes_json = JSON.generate(recipes_data).gsub("</", "<\\/")
%>
<script type="application/json" id="plan-recipes-data"><%= safe(recipes_json) %></script>

<article class="plan">
  <header class="plan-head">
    <h1 class="plan-head__title">Meal plan</h1>
    <p class="plan-head__lede" data-plan-empty>
      Add recipes from anywhere on the site — they'll appear here grouped by meal,
      with a reconciled shopping list below.
    </p>
  </header>

  <section class="plan-mode-toggle" aria-label="Plan mode">
    <label class="plan-mode-toggle__label">
      <input type="checkbox" class="plan-mode-toggle__input" data-plan-mode-toggle>
      <span class="plan-mode-toggle__track" aria-hidden="true"><span class="plan-mode-toggle__thumb"></span></span>
      <span class="plan-mode-toggle__text">Plan mode</span>
    </label>
    <p class="plan-mode-toggle__hint">
      Off: the site looks like a plain cookbook. On: + buttons appear on every recipe and listing so you can add to your plan from anywhere. Your saved plan is untouched either way.
    </p>
  </section>

  <section class="plan-list" data-plan-list aria-live="polite"></section>

  <section class="plan-shop" data-plan-shop hidden>
    <header class="plan-shop__head">
      <h2 class="plan-shop__title">Shopping list <span class="plan-shop__count" data-plan-shop-count></span></h2>
    </header>

    <div class="plan-shop__items" data-plan-shop-items></div>

    <div class="plan-shop__manual" data-plan-shop-manual hidden>
      <h3 class="plan-shop__subtitle">To add manually</h3>
      <ul class="plan-shop__manual-items" data-plan-shop-manual-items></ul>
    </div>

    <div class="plan-shop__tools" role="toolbar" aria-label="Plan tools">
      <button type="button" class="tool" data-plan-action="copy">Copy shopping list</button>
      <button type="button" class="tool" data-plan-action="share">Export to link</button>
      <button type="button" class="tool" data-plan-action="clear">Clear plan</button>
    </div>
  </section>
</article>
